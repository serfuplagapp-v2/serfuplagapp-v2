# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but DO commit the example template (it has no secrets, only placeholders)
!.env.example

# Documentos de planificación: se mantienen LOCALES y en OneDrive, NO en el repo
# público (incluyen estrategia comercial y el diagnóstico de seguridad de la v1).
/docs/

# Carpeta local de claves/contraseñas — nunca subir al repositorio.
/Claves/
/Secretos/

# Herramientas de migración: dependencias y, sobre todo, datos REALES de clientes
# exportados desde la v1 — JAMÁS subir al repo público.
/migration/node_modules/
/migration/exports/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# Variables de entorno de Serfuplagapp v2
# -----------------------------------------------------------------------------
# Copia este archivo como ".env.local" y reemplaza los valores por los de TU
# proyecto Supabase. En Vercel estas mismas variables se cargan en
# Settings → Environment Variables (NO se suben a GitHub).
# Los valores los encuentras en Supabase → Project Settings → API.
# =============================================================================

# URL del proyecto (algo como https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" / "publishable".
# Es seguro exponerla: la protección real vive en las políticas RLS de la base.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opcional) URL pública del sitio, ej: https://serfuplagapp-v2.vercel.app
# Se usa como respaldo para construir los enlaces de los correos.
NEXT_PUBLIC_SITE_URL=

# Envío de correos (certificados PDF al cliente) — Microsoft Graph, el MISMO
# mecanismo de la v1 (functions/correo.js). Son los secretos GRAPH_* que la v1
# guarda en Firebase (Secret Manager del proyecto serfuplagapp-e436d):
#   GRAPH_TENANT_ID     — id del directorio (tenant) de Azure
#   GRAPH_CLIENT_ID     — id de la aplicación registrada
#   GRAPH_CLIENT_SECRET — secreto de la aplicación
#   GRAPH_SENDER_EMAIL  — casilla remitente (ej: operaciones@serfuplagas.cl)
# Si faltan, la app funciona igual pero el botón "Enviar por correo" avisa
# que está pendiente de configurar.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_EMAIL=
